{
  "version": 8,
  "sources": {
    "osm": {
      "type": "raster",
      "tiles": ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "osm-tiles",
      "type": "raster",
      "source": "osm",
      "paint": {
          "raster-hue-rotate": 10,
          "raster-brightness-min": 0.0,
          "raster-brightness-max": 0.32,
          "raster-saturation": -0.65,
          "raster-contrast": 0.40
      }
    }
  ]
}
